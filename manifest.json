{
   "action": {
      "default_popup": "popup.html",
      "default_title": "Upload with Pixora"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://www.tiktok.com/*" ],
      "run_at": "document_start"
   } ],
   "description": "Enhance your TikTok uploads with HD quality and smooth playback. By Pixora.",
   "host_permissions": [ "https://*.tiktok.com/*", "https://*.tikwm.com/*", "https://*.countik.com/*", "https://*.tiktokcdn.com/*", "https://*.tiktokcdn-us.com/*", "https://tiktok-api-production-bebb.up.railway.app/*", "https://*.p16-sign-va.tiktokcdn.com/*", "https://*.p16-sign-sg.tiktokcdn.com/*", "https://*.p19-sign.tiktokcdn-us.com/*", "https://raw.githubusercontent.com/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "manifest_version": 3,
   "name": "Upload with Pixora",
   "permissions": [ "scripting", "activeTab", "storage", "downloads", "alarms" ],
   "version": "1.1.1",
   "web_accessible_resources": [ {
      "matches": [ "<all_urls>" ],
      "resources": [ "inject.js" ]
   } ]
}

