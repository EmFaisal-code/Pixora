{
   "action": {
      "default_popup": "panel.html",
      "default_title": "Pixora"
   },
   "background": {
      "service_worker": "js/core.js"
   },
   "content_scripts": [ {
      "js": [ "js/bridge.js" ],
      "matches": [ "https://www.tiktok.com/*" ],
      "run_at": "document_start"
   } ],
   "description": "Enhance your TikTok uploads with HD quality and smooth playback. By Pixora.",
   "host_permissions": [ "https://*.tiktok.com/*", "https://*.tikwm.com/*", "https://movecexnjyeaipkklijv.supabase.co/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "manifest_version": 3,
   "name": "Pixora",
   "permissions": [ "scripting", "activeTab", "storage", "tabs", "downloads" ],
   "version": "1.2.1",
   "web_accessible_resources": [ {
      "matches": [ "<all_urls>" ],
      "resources": [ "js/engine.js" ]
   } ]
}
